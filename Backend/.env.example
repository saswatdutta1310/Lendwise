# Project Settings
PROJECT_NAME="LendWise Global"
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (Local PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lendwise
POSTGRES_PORT=5432

# Redis & Celery
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
SECRET_KEY=generate_a_secure_key_here
ALGORITHM=HS256

# --- CORE APIS (Only 2 required) ---

# 1. Google Gemini (OCR + AI Insights)
# Get it at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key

# 2. Twilio (SMS + WhatsApp Notifications)
# Get it at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# WhatsApp Webhook Verification
WHATSAPP_VERIFY_TOKEN=LendWise_Verify_2024
WHATSAPP_APP_SECRET=your_meta_app_secret

# --- OPTIONAL ---
# Blockchain (Polygon)
BLOCKCHAIN_PRIVATE_KEY=your_private_key
